SELECT id, username, role
FROM users;</sql><sql name="SQL 3*">SELECT user_id, coin, balance
FROM wallets
ORDER BY user_id, coin;</sql><sql name="SQL 4*">SELECT * FROM wallets;</sql><sql name="SQL 5*">INSERT INTO wallets (user_id, coin, balance) VALUES
