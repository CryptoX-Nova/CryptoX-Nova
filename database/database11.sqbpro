(2,'SOL',0),
(3,'USDT',0),
(3,'BTC',0),
(3,'ETH',0),
(3,'SOL',0);</sql><sql name="SQL 6*">CREATE TABLE trades (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER,
    coin TEXT,
    type TEXT,
    amount REAL,
    price REAL,
    total REAL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);</sql><sql name="SQL 7*">SELECT * FROM wallets;</sql><sql name="SQL 8*">SELECT * FROM wallets;</sql><sql name="SQL 9*">CREATE TABLE IF NOT EXISTS history (

    id INTEGER PRIMARY KEY AUTOINCREMENT,

    user_id INTEGER,

    type TEXT,

    coin TEXT,

    amount REAL,

    price REAL,

    total REAL,

    created_at DATETIME DEFAULT CURRENT_TIMESTAMP

);</sql><sql name="SQL 12*">SELECT * FROM trades;</sql><sql name="SQL 14*">SELECT * FROM market;</sql><sql name="SQL 15*">SELECT
    wallets.coin,
    wallets.balance,
    COALESCE(market.price,1) AS price
FROM wallets
LEFT JOIN market
ON wallets.coin = market.coin
WHERE wallets.user_id = 2
ORDER BY wallets.coin;</sql><sql name="SQL 16*">SELECT * FROM wallets;</sql><sql name="SQL 17*">DELETE FROM wallets
